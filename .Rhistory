scale_fill_manual(values = condition_colors) +
plot_theme
if (interactive()) print(tokens_overview_plot)
ggsave(
filename = paste0(path, "/03_report/graphs/", file_prefix, "tokens_overview_plot.pdf"),
plot = tokens_overview_plot,
width = 7,
height = 5
)
# ------------------------------------------------------------
# 8. Overview of runtime across conditions
# ------------------------------------------------------------
runtime_overview <- mode_metrics %>%
group_by(condition) %>%
summarise(
total_runs = n(),
mean_runtime_seconds = mean(runtime_seconds, na.rm = TRUE),
.groups = "drop"
)
print(runtime_overview)
runtime_overview_plot <- ggplot(runtime_overview, aes(x = condition, y = mean_runtime_seconds, fill = condition)) +
geom_col() +
geom_text(aes(label = round(mean_runtime_seconds, 2)), vjust = -0.5) +
labs(
x = "Condition",
y = "Mean runtime in seconds",
title = paste0("Mean runtime until task completion by condition", title_suffix)
) +
scale_fill_manual(values = condition_colors) +
plot_theme
if (interactive()) print(runtime_overview_plot)
ggsave(
filename = paste0(path, "/03_report/graphs/", file_prefix, "runtime_overview_plot.pdf"),
plot = runtime_overview_plot,
width = 7,
height = 5
)
}
for (current_smm_mode in c("treatment", "baseline")) {
mode_metrics <- simulation_metrics %>%
filter(smm_mode == current_smm_mode)
if (nrow(mode_metrics) > 0) {
save_overview_plots(mode_metrics, current_smm_mode)
}
}
# ============================================================
# Statistical tests for simulation metrics
# ============================================================
# Clean workspace
if (!is.null(dev.list())) dev.off()
rm(list = ls())
library(tidyverse)
library(emmeans)
library(MASS)
path <- getwd()
# ------------------------------------------------------------
# 1. Load data
# ------------------------------------------------------------
simulation_metrics <- read.csv(paste0(path,
"/01_data/processed/simulation_metrics_20260508_080303.csv"),
na.strings = c("", "NA"),
stringsAsFactors = FALSE
)
# ============================================================
# Statistical tests for simulation metrics
# ============================================================
# Clean workspace
if (!is.null(dev.list())) dev.off()
rm(list = ls())
library(tidyverse)
library(emmeans)
library(MASS)
path <- getwd()
# ------------------------------------------------------------
# 1. Load data
# ------------------------------------------------------------
simulation_metrics <- read.csv(paste0(path,
"/01_data/processed/simulation_metrics_20260508_080303.csv"),
na.strings = c("", "NA"),
stringsAsFactors = FALSE
)
# ------------------------------------------------------------
# 2. Prepare variables
# ------------------------------------------------------------
simulation_metrics <- simulation_metrics %>%
mutate(
condition = factor(
condition,
levels = c("low", "moderate", "high"),
ordered = FALSE
),
decision_correct = as.integer(decision_correct)
)
# Check structure
str(simulation_metrics)
# Quick overview
simulation_metrics %>%
group_by(condition) %>%
summarise(
n = n(),
correct_rate = mean(decision_correct, na.rm = TRUE),
mean_similarity = mean(mean_pairwise_memory_similarity, na.rm = TRUE),
mean_runtime = mean(runtime_seconds, na.rm = TRUE),
mean_tokens = mean(total_tokens, na.rm = TRUE),
mean_turns = mean(agent_turns, na.rm = TRUE),
.groups = "drop"
) %>%
print()
# ============================================================
# 3. Decision quality: logistic regression
# ============================================================
model_decision <- glm(
decision_correct ~ condition,
data = simulation_metrics,
family = binomial
)
summary(model_decision)
# Estimated probabilities and pairwise comparisons
decision_emmeans <- emmeans(
model_decision,
pairwise ~ condition,
type = "response"
)
print(decision_emmeans)
# ============================================================
# 4. Semantic similarity: linear regression / ANOVA
# ============================================================
model_similarity <- lm(
mean_pairwise_memory_similarity ~ condition,
data = simulation_metrics
)
summary(model_similarity)
anova(model_similarity)
# Pairwise comparisons
similarity_emmeans <- emmeans(
model_similarity,
pairwise ~ condition
)
print(similarity_emmeans)
# ============================================================
# 5. Runtime: linear regression, log-transformed
# ============================================================
model_runtime <- lm(
log(runtime_seconds) ~ condition,
data = simulation_metrics
)
summary(model_runtime)
anova(model_runtime)
runtime_emmeans <- emmeans(
model_runtime,
pairwise ~ condition
)
print(runtime_emmeans)
# Back-transformed estimates
runtime_emmeans_response <- emmeans(
model_runtime,
pairwise ~ condition,
type = "response"
)
print(runtime_emmeans_response)
# ============================================================
# 6. Token usage: linear regression, log-transformed
# ============================================================
model_tokens <- lm(
log(total_tokens) ~ condition,
data = simulation_metrics
)
summary(model_tokens)
anova(model_tokens)
tokens_emmeans <- emmeans(
model_tokens,
pairwise ~ condition
)
print(tokens_emmeans)
tokens_emmeans_response <- emmeans(
model_tokens,
pairwise ~ condition,
type = "response"
)
print(tokens_emmeans_response)
# ============================================================
# 7. Agent turns: count model
# ============================================================
# First try Poisson regression
model_turns_poisson <- glm(
agent_turns ~ condition,
data = simulation_metrics,
family = poisson
)
summary(model_turns_poisson)
# Check overdispersion
overdispersion_ratio <- sum(residuals(model_turns_poisson, type = "pearson")^2) /
df.residual(model_turns_poisson)
print(paste("Overdispersion ratio:", round(overdispersion_ratio, 2)))
# If overdispersion ratio is clearly above 1.5 or 2, use negative binomial
model_turns_nb <- glm.nb(
agent_turns ~ condition,
data = simulation_metrics
)
summary(model_turns_nb)
turns_emmeans <- emmeans(
model_turns_nb,
pairwise ~ condition,
type = "response"
)
print(turns_emmeans)
# ============================================================
# 8. Total messages: count model
# ============================================================
model_messages_poisson <- glm(
total_messages ~ condition,
data = simulation_metrics,
family = poisson
)
summary(model_messages_poisson)
messages_overdispersion_ratio <- sum(residuals(model_messages_poisson, type = "pearson")^2) /
df.residual(model_messages_poisson)
print(paste("Messages overdispersion ratio:", round(messages_overdispersion_ratio, 2)))
model_messages_nb <- glm.nb(
total_messages ~ condition,
data = simulation_metrics
)
summary(model_messages_nb)
messages_emmeans <- emmeans(
model_messages_nb,
pairwise ~ condition,
type = "response"
)
print(messages_emmeans)
# ============================================================
# 9. Optional: relationship between similarity and decision quality
# ============================================================
model_similarity_decision <- glm(
decision_correct ~ condition + mean_pairwise_memory_similarity,
data = simulation_metrics,
family = binomial
)
summary(model_similarity_decision)
similarity_decision_emmeans <- emmeans(
model_similarity_decision,
pairwise ~ condition,
type = "response"
)
print(similarity_decision_emmeans)
# ============================================================
# 10. Save compact results as text output
# ============================================================
sink("01_data/processed/statistical_test_results.txt")
cat("============================================================\n")
cat("Decision quality: logistic regression\n")
cat("============================================================\n")
print(summary(model_decision))
print(decision_emmeans)
cat("\n\n============================================================\n")
cat("Semantic similarity: linear regression\n")
cat("============================================================\n")
print(summary(model_similarity))
print(anova(model_similarity))
print(similarity_emmeans)
cat("\n\n============================================================\n")
cat("Runtime: log-linear regression\n")
cat("============================================================\n")
print(summary(model_runtime))
print(anova(model_runtime))
print(runtime_emmeans_response)
cat("\n\n============================================================\n")
cat("Tokens: log-linear regression\n")
cat("============================================================\n")
print(summary(model_tokens))
print(anova(model_tokens))
print(tokens_emmeans_response)
cat("\n\n============================================================\n")
cat("Agent turns: negative binomial regression\n")
cat("============================================================\n")
print(summary(model_turns_nb))
print(turns_emmeans)
cat("\n\n============================================================\n")
cat("Total messages: negative binomial regression\n")
cat("============================================================\n")
print(summary(model_messages_nb))
print(messages_emmeans)
cat("\n\n============================================================\n")
cat("Similarity + condition predicting decision quality\n")
cat("============================================================\n")
print(summary(model_similarity_decision))
print(similarity_decision_emmeans)
sink()
print("test")
